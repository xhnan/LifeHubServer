<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xhn.health.activities.mapper.HealthyActivitiesMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.xhn.health.activities.model.HealthyActivities">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="activity_type" property="activityType"/>
        <result column="start_time" property="startTime"/>
        <result column="duration_minutes" property="durationMinutes"/>
        <result column="calories_burned" property="caloriesBurned"/>
        <result column="description" property="description"/>
        <result column="activity_embedding" property="activityEmbedding" typeHandler="com.xhn.base.mybatis.handler.VectorTypeHandler"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, user_id, activity_type, start_time, duration_minutes, calories_burned,
        description, activity_embedding, created_at
    </sql>

</mapper>
