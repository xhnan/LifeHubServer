<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xhn.health.dietlogs.mapper.HealthDietLogsMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.xhn.health.dietlogs.model.HealthDietLogs">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="meal_time" property="mealTime"/>
        <result column="meal_type" property="mealType"/>
        <result column="food_items" property="foodItems"/>
        <result column="total_calories" property="totalCalories"/>
        <result column="protein_g" property="proteinG"/>
        <result column="carbs_g" property="carbsG"/>
        <result column="fat_g" property="fatG"/>
        <result column="food_embedding" property="foodEmbedding" typeHandler="com.xhn.base.mybatis.handler.VectorTypeHandler"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, user_id, meal_time, meal_type, food_items, total_calories,
        protein_g, carbs_g, fat_g, food_embedding, created_at
    </sql>

</mapper>
